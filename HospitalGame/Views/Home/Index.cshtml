@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Terk Edilmiş Hastane</title>

    <link rel="stylesheet" href="~/css/menu.css">
    <link rel="stylesheet" href="~/css/story.css">
</head>

<body>

    <!-- Kalp Atışı Vignette Karartma Efekti -->
    <div class="vignette"></div>

    <!-- Volumetrik Hareketli Sis Katmanları -->
    <div class="fog-wrapper">
        <div class="fog-layer fog-layer-1"></div>
        <div class="fog-layer fog-layer-2"></div>
    </div>

    <div class="background-overlay"></div>

    <div class="menu-container">

        <h1 class="game-title">
            TERK EDİLMİŞ
            <span>HASTANE</span>
        </h1>

        <p class="slogan">
            Bazı kapılar hiç açılmamalı...
        </p>

        <div class="menu-buttons">

            <button id="btn-new-game"><span>Yeni Oyun</span></button>

            <button><span>Devam Et</span></button>

            <button><span>Ayarlar</span></button>

            <button><span>Çıkış</span></button>

        </div>

    </div>

    <!-- ASP.NET Core MVC yönlendirme linkini dinamik olarak JS'e aktarıyoruz -->
    <script>
            window.gameStartUrl = '@Url.Action("Oyun", "Home")';
    </script>

    <script src="~/js/menu-effects.js"></script>
    <script src="~/js/story.js"></script>
</body>

</html>
