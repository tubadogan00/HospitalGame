        }, 3000);
        }

        // Tetikleyici 6: ÇIKIŞ KAPISINA ULAŞMA (Z < -155.5)
        if (playerZ < -155.5 && !triggeredEvents.escaped) {
        if (finalDoorUnlocked) {
        triggeredEvents.escaped = true;
        isDoorOpening = true;
        planksFalling = true;
        showSubtitle("Mühür kırıldı! Kapı açılıyor!", 3000);
        soundEngine.playScaryMetalThud();

        // Giriş kapısındaki collideryı devre dışı bırak (oyuncu odaya geçebilsin)
        colliders[3] = { minX: 0, maxX: 0, minZ: 0, maxZ: 0 };

        // Görevi güncelle
        document.getElementById('objective-text').textContent = "GÖREV: Başhekim Odasını araştır (Mektubu bul)";
        } else {
        // Eğer henüz son koşu tetiklenmediyse
        showSubtitle("Kapı kalın tahtalarla mühürlenmiş! Buradan çıkış yok gibi...", 2500);
        }
        }

        // Tetikleyici 7: GİZLİ ODAYA GİRİŞ (Z < -175.5)
        if (playerZ < -175.5 && !triggeredEvents.enteredSecretRoom) {
            triggeredEvents.enteredSecretRoom = true;
            document.getElementById('objective-text').textContent = "GÖREV: Odadaki gizli anahtarı bul!";
            showSubtitle("Burası gizli bir oda... Çıkış kapısı kilitli olmalı. Anahtarı aramalıyım.", 4000);
        }

        // Tetikleyici 8: KİLİTLİ KAPIDAN ÇIKIŞ VE ZAFER (Z < -189.2)
        if (playerZ < -189.2 && finalExitDoorOpen && !triggeredEvents.finalVictory) {
            triggeredEvents.finalVictory = true;
            controls.unlock();
            document.getElementById('victory-screen').style.pointerEvents = 'auto';
            document.getElementById('victory-screen').style.opacity = '1';
            soundEngine.stopGeneratorRumble();
            soundEngine.stopEmergencyAlarm();
        }
        }

        function handleMovement(delta) {
        if (!controls.isLocked) return;

        // Oyuncu Hızı (Shift basılıysa koş, fener pilini bir miktar daha hızlı tüketebilir)
        const speedMultiplier = isSprinting ? 5.8 : 3.2;
        const moveSpeed = speedMultiplier * delta;

        // Eski Pozisyonu Yedekle (Çarpışma durumunda geri almak için)
        const oldX = camera.position.x;
        const oldZ = camera.position.z;

        // Kamera Yön Vektörleri
        const direction = new THREE.Vector3();
        camera.getWorldDirection(direction);

        // Sadece yatay düzlemde hareket etmek için Y bileşenini sıfırla ve normalize et
        direction.y = 0;
        direction.normalize();

        // Sağa/Sola bakış yön vektörü
        const sideDirection = new THREE.Vector3();
        sideDirection.copy(direction).applyAxisAngle(new THREE.Vector3(0, 1, 0), Math.PI / 2);

        let deltaX = 0;
        let deltaZ = 0;

        if (moveForward) {
        deltaX += direction.x * moveSpeed;
        deltaZ += direction.z * moveSpeed;
        }
        if (moveBackward) {
        deltaX -= direction.x * moveSpeed;
        deltaZ -= direction.z * moveSpeed;
        }
        if (moveLeft) {
            deltaX += sideDirection.x * moveSpeed;
            deltaZ += sideDirection.z * moveSpeed;
        }
        if (moveRight) {
            deltaX -= sideDirection.x * moveSpeed;
            deltaZ -= sideDirection.z * moveSpeed;
        }

        // Yeni Pozisyonu Uygula
        camera.position.x += deltaX;
        camera.position.z += deltaZ;

        // --- ÇARPIŞMA SORGULAMASI (COLLISION RESOLUTION) ---
        const pX = camera.position.x;
        const pZ = camera.position.z;
        const radius = 0.45; // Oyuncu kalınlığı

        for (let i = 0; i < colliders.length; i++) {
        const col = colliders[i];

        // Oyuncu dairesinin, dikdörtgen çarpışma kutusuyla kesişip kesişmediğini kontrol et
        const closestX = Math.max(col.minX, Math.min(pX, col.maxX));
        const closestZ = Math.max(col.minZ, Math.min(pZ, col.maxZ));

        const distX = pX - closestX;
        const distZ = pZ - closestZ;
        const distanceSq = (distX * distX) + (distZ * distZ);

        if (distanceSq < (radius * radius)) {
        // Çarpışma var! Pozisyonu geri al (Kayıp ekseni engelle)
        // Hangi eksende çarpıştığını bulmak için sadece o eksendeki harekete bakıp çözebiliriz
        camera.position.x = oldX;
        camera.position.z = oldZ;
        break;
        }
        }

        // Oyuncunun tavanın dışına ya da altına uçmasını engelle (Yükseklik sabitleme)
        camera.position.y = 1.65;

        // Hikaye tetikleyicilerini kontrol et
        checkTriggerEvents(camera.position.z);
        }

        function updateFlickeringLights(time) {
        corridorLights.forEach(item => {
        if (item.flickerType === 'steady') return;

        if (time > item.nextFlickerTime) {
        if (item.flickerType === 'rapid') {
        // Hızlı sönüp yanma (Floresan arızası)
        const isOn = Math.random() > 0.15;
        item.light.intensity = isOn ? item.baseIntensity : 0.05;
        item.tube.material.color.setHex(isOn ? 0xfffcd3 : 0x222222);
        item.nextFlickerTime = time + (Math.random() * 0.12 + 0.03);
        } else if (item.flickerType === 'intermittent') {
        // Uzun aralıklarla kesintili sönüş
        const isOff = Math.random() > 0.85;
        item.light.intensity = isOff ? 0.0 : item.baseIntensity;
        item.tube.material.color.setHex(isOff ? 0x111111 : 0xfffcd3);
        item.nextFlickerTime = time + (isOff ? (Math.random() * 1.5 + 0.4) : (Math.random() * 5.0 + 2.0));
        }
        }
        });
        }

        function updateFlashlightAndBattery(delta, time) {
        if (!isFlashlightOn) return;

        // Fener Pilini Tüket (Yavaşça)
        // Shift ile koşarken pil bir nebze daha hızlı giderek gerilimi artırır
        const drainRate = isSprinting ? 0.8 : 0.4;
        batteryPower = Math.max(0.0, batteryPower - drainRate * delta);

        // Pil Seviye Göstergesini Güncelle
        const batteryLvlEl = document.getElementById('battery-level');
        const batteryPercentEl = document.getElementById('battery-percent');
        batteryLvlEl.style.width = `${batteryPower}%`;
        batteryPercentEl.textContent = `${Math.round(batteryPower)}%`;

        // Pil Renk Kodlaması
        if (batteryPower > 50) {
        batteryLvlEl.style.backgroundColor = '#00ff00';
        } else if (batteryPower > 20) {
        batteryLvlEl.style.backgroundColor = '#ffff00';
        } else {
        batteryLvlEl.style.backgroundColor = '#ff0000';
        }

        // Pil Sıfırlandıysa Feneri Kapat
        if (batteryPower <= 0.0) {
        isFlashlightOn = false;
        flashlight.visible = false;
        soundEngine.playFlashlightClick();
        showSubtitle("Lanet olsun, fenerin pili tamamen bitti!", 3500);
        }

        // Kritik Pil Kırpışması (Flickering Flashlight on Low Battery)
        if (batteryPower > 0 && batteryPower < batteryFlickerThreshold) {
        // Rastgele sönüp gelmeler
        if (Math.random() > 0.88) {
        flashlight.visible = false;
        setTimeout(() => { if (isFlashlightOn) flashlight.visible = true; }, Math.random() * 150 + 50);
        }
        }
        }

        // --- ETKİLEŞİM FONKSİYONLARI (MEKTUP & JENERATÖR) ---
        function openSecretLetter() {
        letterOpened = true;
        controls.unlock();
        const overlay = document.getElementById('secret-letter-overlay');
        overlay.style.display = 'flex';
        setTimeout(() => { overlay.style.opacity = '1'; }, 50);
        soundEngine.playFlashlightClick();
        }

        // Kapatma düğmesi dinleyicisi
        document.getElementById('btn-close-letter').addEventListener('click', () => {
        const overlay = document.getElementById('secret-letter-overlay');
        overlay.style.opacity = '0';
        setTimeout(() => {
        overlay.style.display = 'none';
        controls.lock();

        // Mektup okundu aşamasını tetikle
        triggeredEvents.letterRead = true;
        triggerSecondStageEvent();
        }, 500);
        });

        function triggerSecondStageEvent() {
        // 1. Oda ışıklarını KIRMIZI yap
        if (lampLight) {
        lampLight.color.setHex(0xff0000);
        lampLight.intensity = 4.0;
        }
        scene.fog.color.setHex(0x1e0000);
        renderer.setClearColor(0x1e0000);
        ambientLight.color.setHex(0x220505);

        // 2. Kırmızı alarm sirenini çal
        soundEngine.playEmergencyAlarm();

        // 3. Giriş kapısını hızlıca arkasından kapat
        isDoorOpening = false;
        let closeProgress = 0.0;
        const closeInterval = setInterval(() => {
        closeProgress += 0.05;
        if (closeProgress >= 1.0) {
        closeProgress = 1.0;
        clearInterval(closeInterval);
        soundEngine.playScaryMetalThud(); // Kapanma sesi
        showSubtitle("KAPILAR KİLİTLENDİ! Kapana kısıldım!", 3000);
        }
        const maxSlide = (CORRIDOR_WIDTH - 0.6) / 2 - 0.2;
        if (doorPanelL) {
        doorPanelL.position.x = -((CORRIDOR_WIDTH - 0.6)/4) - (maxSlide * (1.0 - closeProgress));
        }
        if (doorPanelR) {
        doorPanelR.position.x = ((CORRIDOR_WIDTH - 0.6)/4) + (maxSlide * (1.0 - closeProgress));
        }
        }, 25);

        // Giriş kapısındaki collideryı geri ekle (oyuncu kaçamasın)
        colliders[3] = { minX: -CORRIDOR_WIDTH/2, maxX: CORRIDOR_WIDTH/2, minZ: -CORRIDOR_LENGTH - 0.5, maxZ: -CORRIDOR_LENGTH + 0.35 };

        // 4. Görevi güncelle
        document.getElementById('objective-text').textContent = "GÖREV: Odanın arkasındaki jeneratörü çalıştır!";
        }

        function activateGenerator() {
        triggeredEvents.genActivated = true;
        soundEngine.playGeneratorRumble();
        soundEngine.playScaryMetalThud();

        // Jeneratör lambasını yeşil yap
        if (genBulb) {
        genBulb.material.color.setHex(0x00ff00);
        }

        // Gizli geçit ışığını aç
        if (exitLight) {
        exitLight.intensity = 4.0;
        }

        // Arka duvarın yukarı kayarak açılmasını sağla
        isBackWallOpening = true;

        // Arka duvar colliderını devre dışı bırak
        if (backWallCollider) {
        backWallCollider.minX = 0;
        backWallCollider.maxX = 0;
        backWallCollider.minZ = 0;
        backWallCollider.maxZ = 0;
        }

        showSubtitle("Bir şeyler çalıştı! Gizli geçit açılıyor!", 3000);
        document.getElementById('objective-text').textContent = "GÖREV: Gizli geçitten geçerek Sektör 4'ten KAÇ!";
        }

        function updateDoorOpening(delta) {
        // Tahta mühürlerin düşme animasyonu
        if (planksFalling) {
        if (plank1) {
        plank1VelocityY -= 9.8 * delta;
        plank1.position.y += plank1VelocityY * delta;
        plank1.position.z += 1.5 * delta;
        plank1RotVelocity += 0.8 * delta;
        plank1.rotation.x += plank1RotVelocity * delta;
        if (plank1.position.y < 0.05) {
        plank1.position.y = 0.05;
        plank1VelocityY = 0;
        }
        }
        if (plank2) {
        plank2VelocityY -= 9.8 * delta;
        plank2.position.y += plank2VelocityY * delta;
        plank2.position.z += 2.0 * delta;
        plank2RotVelocity -= 0.6 * delta;
        plank2.rotation.y += plank2RotVelocity * delta;
        if (plank2.position.y < 0.05) {
        plank2.position.y = 0.05;
        plank2VelocityY = 0;
        }
        }
        }

        // Kapı kanatlarının açılma animasyonu
        if (isDoorOpening) {
        if (doorOpenProgress < 1.0) {
        doorOpenProgress += 0.8 * delta;
        if (doorOpenProgress > 1.0) doorOpenProgress = 1.0;

        const maxSlide = (CORRIDOR_WIDTH - 0.6) / 2 - 0.2;
        if (doorPanelL) {
        doorPanelL.position.x = -((CORRIDOR_WIDTH - 0.6)/4) - (maxSlide * doorOpenProgress);
        }
        if (doorPanelR) {
        doorPanelR.position.x = ((CORRIDOR_WIDTH - 0.6)/4) + (maxSlide * doorOpenProgress);
        }
        }
        }
        }

        function updateEntranceDoor(delta) {
            if (isEntranceDoorOpening) {
                if (entranceDoorOpenProgress < 1.0) {
                    entranceDoorOpenProgress += 0.8 * delta;
                    if (entranceDoorOpenProgress > 1.0) entranceDoorOpenProgress = 1.0;

                    const maxSlide = (CORRIDOR_WIDTH - 0.6) / 2 - 0.2;
                    if (entranceDoorPanelL) {
                        entranceDoorPanelL.position.x = -((CORRIDOR_WIDTH - 0.6)/4) - (maxSlide * entranceDoorOpenProgress);
                    }
                    if (entranceDoorPanelR) {
                        entranceDoorPanelR.position.x = ((CORRIDOR_WIDTH - 0.6)/4) + (maxSlide * entranceDoorOpenProgress);
                    }
                }
            } else if (isEntranceDoorClosing) {
                if (entranceDoorOpenProgress > 0.0) {
                    entranceDoorOpenProgress -= 1.8 * delta; // Closes faster for spookiness!
                    if (entranceDoorOpenProgress < 0.0) {
                        entranceDoorOpenProgress = 0.0;
                        isEntranceDoorClosing = false;
                    }

                    const maxSlide = (CORRIDOR_WIDTH - 0.6) / 2 - 0.2;
                    if (entranceDoorPanelL) {
                        entranceDoorPanelL.position.x = -((CORRIDOR_WIDTH - 0.6)/4) - (maxSlide * entranceDoorOpenProgress);
                    }
                    if (entranceDoorPanelR) {
                        entranceDoorPanelR.position.x = ((CORRIDOR_WIDTH - 0.6)/4) + (maxSlide * entranceDoorOpenProgress);
                    }
                }
            }
        }

        function updateFinalExitDoor(delta) {
            if (isFinalExitDoorOpening) {
                if (finalExitDoorOpenProgress < 1.0) {
                    finalExitDoorOpenProgress += 1.0 * delta;
                    if (finalExitDoorOpenProgress > 1.0) finalExitDoorOpenProgress = 1.0;

                    if (finalExitDoorPanelL) {
                        finalExitDoorPanelL.position.x = -1.5 * finalExitDoorOpenProgress;
                    }
                }
            }
        }

        let genBlinkTimer = 0;

        function animate(time) {
        requestAnimationFrame(animate);

        const delta = clock.getDelta();
        const elapsed = clock.getElapsedTime();

        // Oyuncu Hareketini Güncelle
        handleMovement(delta);

        // Hayalet Süzülme ve Titreme Animasyonu
        if (ghostMesh && ghostMesh.parent) {
            ghostMesh.position.y = 0.1 * Math.sin(elapsed * 4.0);
            ghostMesh.rotation.y = 0.05 * Math.sin(elapsed * 12.0);
        }

        // Anahtar Dönüş Animasyonu
        if (keyMesh && keyMesh.parent) {
            keyMesh.rotation.y += 1.5 * delta;
        }

        // Fenerin Pozisyonunu ve Hedefini Kameraya Bağla
        if (isFlashlightOn) {
        const offset = new THREE.Vector3(0.18, -0.15, -0.1);
        offset.applyQuaternion(camera.quaternion);
        flashlight.position.copy(camera.position).add(offset);

        const targetDir = new THREE.Vector3(0, 0, -1);
        targetDir.applyQuaternion(camera.quaternion);
        flashlight.target.position.copy(camera.position).add(targetDir);
        }

        // Nabız ve vignette güncellemeleri
        if (controls.isLocked) {
        if (isSprinting) {
        soundEngine.setBPM(120);
        document.getElementById('vignette').classList.add('panic');
        } else {
        // Dinamik durum bazlı nabız
        if (triggeredEvents.finalVictory) {
        soundEngine.setBPM(72);
        } else if (triggeredEvents.letterRead) {
        soundEngine.setBPM(140); // Siren çalıyor panik
        document.getElementById('vignette').classList.add('panic');
        } else if (triggeredEvents.finalRun) {
        soundEngine.setBPM(145);
        document.getElementById('vignette').classList.add('panic');
        } else if (triggeredEvents.ghostHallucination) {
        soundEngine.setBPM(95);
        } else if (triggeredEvents.flickerOut) {
        soundEngine.setBPM(115);
        } else if (triggeredEvents.metalThud) {
        soundEngine.setBPM(100);
        } else if (triggeredEvents.whisper1) {
        soundEngine.setBPM(85);
        } else {
        soundEngine.setBPM(72);
        document.getElementById('vignette').classList.remove('panic');
        }
        }
        }

        // Etkileşimler Menzil Kontrolü
        const interactionPrompt = document.getElementById('interaction-prompt');
        let promptShown = false;
        
        isNearKey = false;
        isNearFinalExitDoor = false;
        isNearEntranceDoor = false;
        isNearLetter = false;
        isNearGen = false;

        if (controls.isLocked) {
            if (triggeredEvents.enteredSecretRoom) {
                // 1. Anahtar Etkileşimi
                const distToKey = Math.sqrt((camera.position.x - (-1.8)) ** 2 + (camera.position.z - (-182)) ** 2);
                if (!hasKey && distToKey < 1.8) {
                    interactionPrompt.textContent = "[E] Anahtarı Al";
                    interactionPrompt.style.display = 'block';
                    isNearKey = true;
                    promptShown = true;
                } 
                // 2. Final Kapı Etkileşimi
                else {
                    const distToFinalExit = Math.sqrt((camera.position.x - 0) ** 2 + (camera.position.z - (-189)) ** 2);
                    if (!finalExitDoorOpen && distToFinalExit < 2.0) {
                        if (hasKey) {
                            interactionPrompt.textContent = "[E] Çıkış Kapısının Kilidini Aç";
                        } else {
                            interactionPrompt.textContent = "Kapı Kilitli (Anahtara ihtiyacın var)";
                        }
                        interactionPrompt.style.display = 'block';
                        isNearFinalExitDoor = true;
                        promptShown = true;
                    }
                }
            } else {
                // 3. Giriş Kapısı Etkileşimi
                if (!triggeredEvents.enteredHospital) {
                    const distToEntrance = Math.sqrt((camera.position.x - 0) ** 2 + (camera.position.z - 0) ** 2);
                    if (distToEntrance < 2.5 && entranceDoorOpenProgress === 0) {
                        interactionPrompt.textContent = "[E] Hastane Kapısını Aç";
                        interactionPrompt.style.display = 'block';
                        isNearEntranceDoor = true;
                        promptShown = true;
                    }
                }
                
                if (!promptShown) {
                    // 4. Mektup Etkileşimi
                    const distToLetter = Math.sqrt((camera.position.x - 2.8) ** 2 + (camera.position.z - -170.8) ** 2);
                    if (triggeredEvents.escaped && !triggeredEvents.letterRead && distToLetter < 2.0) {
                        interactionPrompt.textContent = "[E] Dr. Aris'in Notunu Oku";
                        interactionPrompt.style.display = 'block';
                        isNearLetter = true;
                        promptShown = true;
                    }
                    // 5. Jeneratör Etkileşimi
                    else {
                        const distToGen = Math.sqrt((camera.position.x - 0) ** 2 + (camera.position.z - -174.4) ** 2);
                        if (triggeredEvents.letterRead && !triggeredEvents.genActivated && distToGen < 1.8) {
                            interactionPrompt.textContent = "[E] Jeneratörü Aktif Et";
                            interactionPrompt.style.display = 'block';
                            isNearGen = true;
                            promptShown = true;
                        }
                    }
                }
            }
        }

        if (!promptShown) {
            interactionPrompt.style.display = 'none';
        }

        // Jeneratör LED Işığı Kırpışması
        if (triggeredEvents.letterRead && !triggeredEvents.genActivated && genBulb) {
        genBlinkTimer += delta;
        if (genBlinkTimer > 0.5) {
        genBlinkTimer = 0;
        genBulb.material.color.setHex(genBulb.material.color.getHex() === 0xff0000 ? 0x220000 : 0xff0000);
        }
        }

        // Gizli Geçit Kapısının Yukarı Kayma Animasyonu
        if (isBackWallOpening && backWall && backWall.position.y < CORRIDOR_HEIGHT * 1.5) {
        backWall.position.y += 1.5 * delta;
        }

        // Lambaların Kırpışmasını Güncelle
        updateFlickeringLights(elapsed);

        // Fener Batarya ve Kırpışmasını Güncelle
        updateFlashlightAndBattery(delta, elapsed);

        // Kapı Açılmasını Güncelle
        updateDoorOpening(delta);
        updateEntranceDoor(delta);
        updateFinalExitDoor(delta);

        // Render Et
        renderer.render(scene, camera);
        }

        // Pencere Boyut Değişim Desteği
        window.addEventListener('resize', () => {
        renderer.setSize(window.innerWidth, window.innerHeight);
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        });

        // Oyunu ve Animasyon Döngüsünü Başlat
        animate();
    </script>
</body>
</html>