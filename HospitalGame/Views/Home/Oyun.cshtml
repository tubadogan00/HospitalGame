@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Terk Edilmiş Hastane - Sektör 4</title>
    <link href="https://fonts.googleapis.com/css2?family=Creepster&family=Special+Elite&display=swap" rel="stylesheet">
    <style>
            body, html {
                margin: 0;
                padding: 0;
                width: 100%;
                height: 100%;
                overflow: hidden;
                background-color: #000;
                font-family: 'Special Elite', monospace;
                user-select: none;
            }

            #game-container {
                width: 100%;
                height: 100%;
                position: absolute;
                top: 0;
                left: 0;
                z-index: 1;
            }

            /* Korkutucu Arayüz Elemanları */
            #ui-overlay {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                z-index: 10;
                pointer-events: none;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                padding: 25px;
                box-sizing: border-box;
            }

            /* Vignette (Kenar Karartması) ve Kan Efekti */
            #vignette {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                z-index: 2;
                pointer-events: none;
                box-shadow: inset 0 0 100px rgba(0,0,0,0.9), inset 0 0 200px rgba(0,0,0,0.95);
                transition: box-shadow 0.5s ease;
            }

            #vignette.panic {
                box-shadow: inset 0 0 120px rgba(139,0,0,0.85), inset 0 0 220px rgba(0,0,0,0.95);
            }

            /* Başlangıç Ekranı */
            #blocker {
                position: absolute;
                width: 100%;
                height: 100%;
                background-color: rgba(0,0,0,0.95);
                z-index: 100;
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                color: #ccc;
                cursor: pointer;
                text-align: center;
                transition: opacity 0.3s ease;
            }

            #blocker h1 {
                font-family: 'Creepster', cursive;
                font-size: 75px;
                color: #8b0000;
                margin-bottom: 5px;
                letter-spacing: 3px;
                text-shadow: 0 0 15px rgba(139,0,0,0.6);
                animation: pulse 2s infinite alternate;
            }

            #blocker p.sub {
                font-size: 18px;
                color: #888;
                margin-bottom: 40px;
                max-width: 600px;
                line-height: 1.6;
            }

            #blocker .btn-start {
                background-color: #1a0000;
                border: 2px solid #8b0000;
                color: #ffcccc;
                padding: 15px 40px;
                font-family: 'Special Elite', monospace;
                font-size: 20px;
                cursor: pointer;
                transition: all 0.3s ease;
                box-shadow: 0 0 15px rgba(139,0,0,0.3);
            }

            #blocker .btn-start:hover {
                background-color: #8b0000;
                color: #fff;
                box-shadow: 0 0 25px rgba(139,0,0,0.8);
                transform: scale(1.05);
            }

            #blocker .controls-guide {
                margin-top: 50px;
                font-size: 13px;
                color: #666;
                text-align: left;
                border: 1px dashed rgba(139,0,0,0.3);
                padding: 20px 30px;
                border-radius: 5px;
                background: rgba(10,10,10,0.5);
            }

            #blocker .controls-guide table td {
                padding: 5px 15px;
            }

            /* Oyun İçi HUD */
            .hud-element {
                pointer-events: none;
                text-shadow: 0 0 5px #000, 0 0 10px #000;
            }

            #heart-rate-panel {
                display: flex;
                align-items: center;
                gap: 15px;
                color: #8b0000;
            }

            #heart-rate-text {
                font-size: 18px;
                font-weight: bold;
                letter-spacing: 1px;
                color: #ff3333;
            }

            /* Nabız Çizgisi Animasyonu (ECG) */
            #ecg-svg {
                width: 120px;
                height: 40px;
                stroke: #ff3333;
                fill: none;
                stroke-width: 2;
                stroke-linecap: round;
            }

            .ecg-line {
                stroke-dasharray: 600;
                stroke-dashoffset: 600;
                animation: ecgDash 2.5s linear infinite;
            }

            #flashlight-panel {
                font-size: 16px;
                color: #dfd7c2;
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .battery-icon {
                width: 45px;
                height: 20px;
                border: 2px solid #dfd7c2;
                padding: 2px;
                position: relative;
                display: flex;
            }

            .battery-icon::after {
                content: '';
                position: absolute;
                right: -6px;
                top: 4px;
                width: 4px;
                height: 8px;
                background-color: #dfd7c2;
            }

            #battery-level {
                height: 100%;
                width: 100%;
                background-color: #00ff00;
                transition: width 0.3s ease, background-color 0.3s ease;
            }

            #objective-text {
                align-self: center;
                color: #ff3333;
                font-size: 20px;
                letter-spacing: 2px;
                text-align: center;
                max-width: 80%;
                animation: flashText 4s infinite;
            }

            #subtitles {
                align-self: center;
                font-size: 18px;
                color: #dfd7c2;
                background-color: rgba(0, 0, 0, 0.7);
                padding: 8px 20px;
                border-radius: 4px;
                max-width: 70%;
                text-align: center;
                opacity: 0;
                transition: opacity 0.5s ease;
                border-left: 3px solid #8b0000;
                margin-bottom: 20px;
            }

            #subtitles.active {
                opacity: 1;
            }

            #crosshair {
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                width: 6px;
                height: 6px;
                background-color: rgba(255,255,255,0.2);
                border-radius: 50%;
                z-index: 5;
                pointer-events: none;
            }

            /* Jumpscare Görsel Efekti */
            #flash-overlay {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background-color: #ff0000;
                z-index: 99;
                opacity: 0;
                pointer-events: none;
                transition: opacity 0.1s ease;
            }

            #scare-ghost {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background-color: #000;
                background-image: radial-gradient(circle, rgba(139,0,0,0.5) 0%, rgba(0,0,0,1) 80%);
                z-index: 101;
                display: flex;
                justify-content: center;
                align-items: center;
                opacity: 0;
                pointer-events: none;
                transition: opacity 0.05s ease;
                overflow: hidden;
            }

            #scare-ghost img {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                object-fit: cover;
                opacity: 0.85;
                filter: contrast(1.3) brightness(0.9);
                transform: scale(1.1);
            }

            @@keyframes scare-shake {
                0% { transform: translate(1px, 1px) rotate(0deg) scale(1.2); }
                10% { transform: translate(-1px, -2px) rotate(-1deg) scale(1.2); }
                20% { transform: translate(-3px, 0px) rotate(1deg) scale(1.25); }
                30% { transform: translate(0px, 2px) rotate(0deg) scale(1.2); }
                40% { transform: translate(1px, -1px) rotate(1deg) scale(1.25); }
                50% { transform: translate(-1px, 2px) rotate(-1deg) scale(1.2); }
                60% { transform: translate(-3px, 1px) rotate(0deg) scale(1.2); }
                70% { transform: translate(2px, 1px) rotate(-1deg) scale(1.25); }
                80% { transform: translate(-1px, -1px) rotate(1deg) scale(1.2); }
                90% { transform: translate(2px, 2px) rotate(0deg) scale(1.25); }
                100% { transform: translate(1px, -2px) rotate(-1deg) scale(1.2); }
            }

            #scare-ghost.active img {
                animation: scare-shake 0.15s infinite;
            }

            #scare-ghost h2 {
                font-family: 'Creepster', cursive;
                font-size: 140px;
                color: #ff0000;
                margin: 0;
                letter-spacing: 15px;
                text-shadow: 0 0 50px #ff0000;
                transform: scale(0.6);
                transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                z-index: 102;
            }

            #scare-ghost.active h2 {
                transform: scale(1.2);
            }

            /* Kurtuluş/Bitiş Ekranı */
            #victory-screen {
                position: absolute;
                width: 100%;
                height: 100%;
                background-color: #000;
                z-index: 200;
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                color: #dfd7c2;
                text-align: center;
                opacity: 0;
                pointer-events: none;
                transition: opacity 2s ease;
            }

            #victory-screen h1 {
                font-family: 'Creepster', cursive;
                font-size: 80px;
                color: #00ff00;
                margin-bottom: 20px;
                text-shadow: 0 0 20px rgba(0,255,0,0.5);
            }

            #victory-screen p {
                font-size: 20px;
                max-width: 600px;
                line-height: 1.8;
                margin-bottom: 40px;
            }

            #victory-screen .btn-back {
                background-color: #001a00;
                border: 2px solid #00ff00;
                color: #ccffcc;
                padding: 15px 40px;
                font-family: 'Special Elite', monospace;
                font-size: 18px;
                cursor: pointer;
                transition: all 0.3s ease;
            }

            #victory-screen .btn-back:hover {
                background-color: #00ff00;
                color: #000;
                box-shadow: 0 0 20px rgba(0,255,0,0.6);
            }

            /* Animasyonlar */
            @@keyframes pulse {
                0% { transform: scale(1); text-shadow: 0 0 15px rgba(139,0,0,0.6); }
                100% { transform: scale(1.03); text-shadow: 0 0 30px rgba(139,0,0,0.9), 0 0 50px rgba(255,0,0,0.4); }
            }

            @@keyframes ecgDash {
                to { stroke-dashoffset: 0; }
            }

            @@keyframes flashText {
                0%, 100% { opacity: 0.6; text-shadow: 0 0 5px rgba(255,0,0,0.4); }
                50% { opacity: 1; text-shadow: 0 0 15px rgba(255,0,0,0.9), 0 0 5px #000; }
            }
    </style>

    <!-- Three.js ve PointerLockControls Kütüphaneleri -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/PointerLockControls.js"></script>
</head>
<body>

    <div id="blocker">
        <div id="instructions">
            <h1>SEKTÖR 4</h1>
            <p class="sub">Umut Vadisi Psikiyatri Hastanesi'nin derinliklerinde gizli ve mühürlenmiş Sektör 4'e ulaştın. Kendini kurtarmak için mühürlü ana kapıyı bulmalısın. Fenerine ve adımlarına dikkat et... Karanlıkta yalnız değilsin.</p>

            <button class="btn-start" id="btn-start-game">KAPIDAN İÇERİ GİR</button>

            <div class="controls-guide">
                <table>
                    <tr>
                        <td><strong>W, A, S, D</strong></td>
                        <td>Hareket Et (Yürü)</td>
                    </tr>
                    <tr>
                        <td><strong>Sol Tık / F</strong></td>
                        <td>Feneri Aç / Kapa</td>
                    </tr>
                    <tr>
                        <td><strong>Shift</strong></td>
                        <td>Hızlı Koş (Sürat)</td>
                    </tr>
                    <tr>
                        <td><strong>Mouse</strong></td>
                        <td>Etrafına Bak (Fareyi kilitlemek için ekrana tıklayın)</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    <!-- Jumpscare ve Flaş Efektleri -->
    <div id="flash-overlay"></div>
    <div id="scare-ghost">
        <img src="/images/scary_ghost.jpg" alt="Ghost Jumpscare" />
        <h2>O BURADA!</h2>
    </div>

    <!-- Zafer / Kaçış Ekranı -->
    <div id="victory-screen">
        <h1>HAYATTASIN!</h1>
        <p>Sektör 4'ün kabus dolu koridorlarından ve gizli laboratuvarından geçerek mühürlü çıkış kapısını açmayı başardın. Hastanenin karanlığı arkanda kalırken, akciğerlerini dolduran temiz gece havası sana hala yaşadığını fısıldıyor...</p>
        <button class="btn-back" onclick="window.location.href='/'">ANA MENÜYE DÖN</button>
    </div>

    <!-- Etkileşim Uyarısı -->
    <div id="interaction-prompt" style="position: absolute; bottom: 25%; left: 50%; transform: translateX(-50%); font-size: 20px; color: #dfd7c2; background-color: rgba(0,0,0,0.85); padding: 12px 25px; border-radius: 4px; display: none; pointer-events: none; border-left: 4px solid #8b0000; z-index: 100; font-family: 'Special Elite', monospace; text-shadow: 0 0 5px #000; box-shadow: 0 0 15px rgba(0,0,0,0.5);">[E] OKU</div>

    <!-- Gizli Mektup Arayüzü -->
    <div id="secret-letter-overlay" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.9); z-index: 150; display: none; justify-content: center; align-items: center; opacity: 0; transition: opacity 0.5s ease;">
        <div class="letter-container" style="background: #eedfa9; color: #1c130c; font-family: 'Special Elite', monospace; padding: 45px; border-radius: 4px; box-shadow: 0 0 35px rgba(0,0,0,0.9); max-width: 600px; width: 85%; border: 15px solid #2e2417; position: relative;">
            <div style="font-weight: bold; font-size: 14px; border-bottom: 2px solid #5a4b35; padding-bottom: 5px; margin-bottom: 20px; display: flex; justify-content: space-between;">
                <span>SEKTÖR 4 - ÖZEL LABORATUVAR</span>
                <span>12 Kasım 1974</span>
            </div>
            <div style="font-size: 16px; line-height: 1.6; margin-bottom: 30px;">
                <p><strong>GİZLİ HASTA RAPORU - BAŞHEKİM DR. ARIS</strong></p>
                <p>Sonunda başardık... Sektör 4'te elektroşok kullanarak zihnin karanlık kapılarını açtık. Ancak bu uyarım, hastaların sadece hafızasını silmedi, aynı zamanda zihinlerinde uyuyan bir "şeyi" uyandırdı.</p>
                <p>Deneklerin hepsi aynı şeyi söylüyor: <em>"O, ışıklar söndüğünde besleniyor."</em> Onu kontrol edemiyoruz. Duvarlardan sızan o siyah gölge, artık kontrolümüzün tamamen dışına çıktı.</p>
                <p>Eğer bu notu okuyorsan, kapıyı kilitlemek için çok geç kalmışsın demektir. Sektör 4'ün çıkış kodunu Başhekimlik Odası'ndaki gizli geçit panelinde aktif ettim. Çıkış kapısı kilitlendiğinde, odanın arkasındaki jeneratörü kırmızı alarm moduna al. Ve sakın arkana bakma...</p>
            </div>
            <div style="display: flex; justify-content: flex-end;">
                <button id="btn-close-letter" style="background: #2a221a; color: #dfd7c2; border: 1px solid #5a4b35; padding: 10px 25px; font-family: 'Special Elite', monospace; font-size: 16px; cursor: pointer; transition: all 0.3s; box-shadow: 0 0 10px rgba(0,0,0,0.3);">Kapat ve İlerle</button>
            </div>
        </div>
    </div>

    <div id="vignette"></div>
    <div id="crosshair"></div>

    <div id="ui-overlay">
        <!-- ÜST PANEL: Görev ve Fener -->
        <div style="display: flex; justify-content: space-between; width: 100%;">
            <div id="flashlight-panel" class="hud-element">
                <span>FENER:</span>
                <div class="battery-icon">
                    <div id="battery-level"></div>
                </div>
                <span id="battery-percent">100%</span>
            </div>

            <div id="heart-rate-panel" class="hud-element">
                <span id="heart-rate-text">NABIZ: 72 BPM</span>
                <svg id="ecg-svg" viewBox="0 0 100 30">
                    <path class="ecg-line" d="M0,15 L30,15 L35,5 L40,25 L45,12 L50,15 L100,15" />
                </svg>
            </div>
        </div>

        <!-- ORTA PANEL: Görev ve Mesajlar -->
        <div id="objective-text" class="hud-element">GÖREV: Hastane kapısından içeri gir</div>

        <!-- ALT PANEL: Altyazılar -->
        <div id="subtitles"></div>
    </div>

    <div id="game-container"></div>

    <script>
        // --- SES SENTEZLEYİCİ VE SES MOTORU (Web Audio API - Tamamen Ücretsiz ve Bağımsız) ---
        class HorrorSoundEngine {
        constructor() {
        this.ctx = null;
        this.ambientNode = null;
        this.windNode = null;
        this.heartbeatTimer = null;
        this.heartbeatBPM = 72;
        this.isInitialized = false;
        }

        init() {
        if (this.isInitialized) return;
        try {
        const AudioContext = window.AudioContext || window.webkitAudioContext;
        this.ctx = new AudioContext();
        this.isInitialized = true;

        // 1. Arka Plan Korku Drone Sesi (Uğultu)
        this.playAmbientDrone();
        // 2. Rüzgar / HVAC Filtre Sesi
        this.playWindNoise();
        // 3. Kalp Atışını Başlat
        this.startHeartbeatLoop();

        console.log("Korku Ses Motoru Başarıyla Yüklendi.");
        } catch(e) {
        console.warn("Ses tarayıcı tarafından engellendi veya desteklenmiyor:", e);
        }
        }

        playAmbientDrone() {
        // İki çok düşük frekanslı osilatör ile vuruşlu (scary beating) derin uğultu oluşturma
        const osc1 = this.ctx.createOscillator();
        const osc2 = this.ctx.createOscillator();
        const gain = this.ctx.createGain();
        const filter = this.ctx.createBiquadFilter();

        osc1.type = 'sawtooth';
        osc1.frequency.value = 55; // A1 nota frekansı civarı

        osc2.type = 'sine';
        osc2.frequency.value = 55.8; // Hafif faz sapması ürpertici vuruş yaratır

        filter.type = 'lowpass';
        filter.frequency.value = 110; // Sadece bas sesleri geçir
        filter.Q.value = 3;

        gain.gain.value = 0.12;

        osc1.connect(filter);
        osc2.connect(filter);
        filter.connect(gain);
        gain.connect(this.ctx.destination);

        osc1.start();
        osc2.start();

        this.ambientNode = { osc1, osc2, gain };
        }

        playWindNoise() {
        // Beyaz gürültü oluşturup dar bir bant geçiren filtreyle rüzgar uğultusu taklidi yapalım
        const bufferSize = this.ctx.sampleRate * 2;
        const noiseBuffer = this.ctx.createBuffer(1, bufferSize, this.ctx.sampleRate);
        const output = noiseBuffer.getChannelData(0);
        for (let i = 0; i < bufferSize; i++) {
        output[i] = Math.random() * 2 - 1;
        }

        const whiteNoise = this.ctx.createBufferSource();
        whiteNoise.buffer = noiseBuffer;
        whiteNoise.loop = true;

        const filter = this.ctx.createBiquadFilter();
        filter.type = 'bandpass';
        filter.frequency.value = 300;
        filter.Q.value = 1.5;

        const gain = this.ctx.createGain();
        gain.gain.value = 0.05;

        // Rüzgar uğultusunun gücünü ve frekansını rastgele dalgalandır
        setInterval(() => {
        if (this.ctx && this.ctx.state === 'running') {
        const t = this.ctx.currentTime;
        filter.frequency.exponentialRampToValueAtTime(200 + Math.random() * 250, t + 2);
        gain.gain.linearRampToValueAtTime(0.02 + Math.random() * 0.05, t + 2);
        }
        }, 2000);

        whiteNoise.connect(filter);
        filter.connect(gain);
        gain.connect(this.ctx.destination);
        whiteNoise.start();

        this.windNode = whiteNoise;
        }

        playHeartbeat() {
        if (!this.ctx || this.ctx.state !== 'running') return;
        const t = this.ctx.currentTime;

        // Kalp atışı çifte vurur (lub-dub)
        this.triggerThump(t);
        this.triggerThump(t + 0.18);
        }

        triggerThump(time) {
        const osc = this.ctx.createOscillator();
        const gain = this.ctx.createGain();

        osc.type = 'sine';
        osc.frequency.setValueAtTime(65, time);
        // Frekansı hızla sıfıra düşürerek tok bir vuruş elde et
        osc.frequency.exponentialRampToValueAtTime(0.01, time + 0.15);

        gain.gain.setValueAtTime(0.5, time);
        gain.gain.exponentialRampToValueAtTime(0.01, time + 0.15);

        osc.connect(gain);
        gain.connect(this.ctx.destination);
        osc.start(time);
        osc.stop(time + 0.16);
        }

        startHeartbeatLoop() {
        const runLoop = () => {
        this.playHeartbeat();
        const interval = (60 / this.heartbeatBPM) * 1000;
        this.heartbeatTimer = setTimeout(runLoop, interval);
        };
        runLoop();
        }

        setBPM(bpm) {
        this.heartbeatBPM = Math.max(60, Math.min(bpm, 160));
        document.getElementById('heart-rate-text').textContent = `NABIZ: ${Math.round(this.heartbeatBPM)} BPM`;

        // ECG Animasyon hızını senkronize et
        const speed = 180 / this.heartbeatBPM;
        document.querySelector('.ecg-line').style.animationDuration = `${speed}s`;
        }

        playFlashlightClick() {
        if (!this.ctx) return;
        const osc = this.ctx.createOscillator();
        const gain = this.ctx.createGain();
        osc.type = 'sine';
        osc.frequency.setValueAtTime(1200, this.ctx.currentTime);
        osc.frequency.exponentialRampToValueAtTime(800, this.ctx.currentTime + 0.05);

        gain.gain.setValueAtTime(0.08, this.ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, this.ctx.currentTime + 0.05);

        osc.connect(gain);
        gain.connect(this.ctx.destination);
        osc.start();
        osc.stop(this.ctx.currentTime + 0.06);
        }

        playScaryMetalThud() {
        if (!this.ctx) return;
        const t = this.ctx.currentTime;
        // Derin metal darbesi
        const osc = this.ctx.createOscillator();
        const gain = this.ctx.createGain();
        const filter = this.ctx.createBiquadFilter();

        osc.type = 'triangle';
        osc.frequency.setValueAtTime(150, t);
        osc.frequency.exponentialRampToValueAtTime(20, t + 1.5);

        filter.type = 'lowpass';
        filter.frequency.setValueAtTime(250, t);

        gain.gain.setValueAtTime(0.4, t);
        gain.gain.exponentialRampToValueAtTime(0.001, t + 1.5);

        // Metalik çınlama (Gürültüyle)
        const noiseNode = this.ctx.createBufferSource();
        const bufferSize = this.ctx.sampleRate * 0.5;
        const buffer = this.ctx.createBuffer(1, bufferSize, this.ctx.sampleRate);
        const data = buffer.getChannelData(0);
        for(let i=0; i<bufferSize; i++) data[i] = Math.random() * 2 - 1;
        noiseNode.buffer = buffer;

        const noiseGain = this.ctx.createGain();
        const noiseFilter = this.ctx.createBiquadFilter();
        noiseFilter.type = 'bandpass';
        noiseFilter.frequency.value = 600;
        noiseFilter.Q.value = 5;

        noiseGain.gain.setValueAtTime(0.12, t);
        noiseGain.gain.exponentialRampToValueAtTime(0.001, t + 0.4);

        noiseNode.connect(noiseFilter);
        noiseFilter.connect(noiseGain);
        noiseGain.connect(this.ctx.destination);
        noiseNode.start(t);

        osc.connect(filter);
        filter.connect(gain);
        gain.connect(this.ctx.destination);

        osc.start(t);
        osc.stop(t + 1.6);
        }

        playScreechJumpscare() {
        if (!this.ctx) return;
        const t = this.ctx.currentTime;
        // Şiddetli ve korkunç bir metal sürtmesi/çığlık sentezi
        const duration = 1.2;

        const osc1 = this.ctx.createOscillator();
        const osc2 = this.ctx.createOscillator();
        const gain = this.ctx.createGain();
        const filter = this.ctx.createBiquadFilter();

        osc1.type = 'sawtooth';
        osc1.frequency.setValueAtTime(800, t);
        osc1.frequency.linearRampToValueAtTime(300, t + duration);

        osc2.type = 'sawtooth';
        osc2.frequency.setValueAtTime(815, t);
        osc2.frequency.linearRampToValueAtTime(290, t + duration);

        // Frekans dalgalanması (Spooky vibrato)
        const vibrato = this.ctx.createOscillator();
        const vibratoGain = this.ctx.createGain();
        vibrato.frequency.value = 25;
        vibratoGain.gain.value = 50;
        vibrato.connect(vibratoGain);
        vibratoGain.connect(osc1.frequency);
        vibratoGain.connect(osc2.frequency);

        filter.type = 'peaking';
        filter.frequency.value = 2000;
        filter.Q.value = 2;

        gain.gain.setValueAtTime(0.35, t);
        gain.gain.exponentialRampToValueAtTime(0.001, t + duration);

        osc1.connect(filter);
        osc2.connect(filter);
        filter.connect(gain);
        gain.connect(this.ctx.destination);

        vibrato.start(t);
        osc1.start(t);
        osc2.start(t);

        vibrato.stop(t + duration);
        osc1.stop(t + duration);
        osc2.stop(t + duration);
        }

        playEmergencyAlarm() {
        if (!this.ctx) return;
        const t = this.ctx.currentTime;

        const osc = this.ctx.createOscillator();
        const gain = this.ctx.createGain();

        osc.type = 'sawtooth';
        osc.frequency.setValueAtTime(220, t);

        const lfo = this.ctx.createOscillator();
        const lfoGain = this.ctx.createGain();
        lfo.frequency.value = 1.5;
        lfoGain.gain.value = 100;

        lfo.connect(lfoGain);
        lfoGain.connect(osc.frequency);

        gain.gain.setValueAtTime(0.0, t);
        gain.gain.linearRampToValueAtTime(0.08, t + 0.5);

        osc.connect(gain);
        gain.connect(this.ctx.destination);

        lfo.start(t);
        osc.start(t);

        this.alarmNode = { osc, lfo, gain };
        }

        stopEmergencyAlarm() {
        if (this.alarmNode) {
        const t = this.ctx.currentTime;
        this.alarmNode.gain.gain.linearRampToValueAtTime(0.0, t + 0.5);
        const localAlarmNode = this.alarmNode;
        setTimeout(() => {
        try {
        localAlarmNode.osc.stop();
        localAlarmNode.lfo.stop();
        } catch(e){}
        }, 600);
        this.alarmNode = null;
        }
        }

        playGeneratorRumble() {
        if (!this.ctx) return;
        const t = this.ctx.currentTime;

        const osc = this.ctx.createOscillator();
        const gain = this.ctx.createGain();
        const filter = this.ctx.createBiquadFilter();

        osc.type = 'sawtooth';
        osc.frequency.setValueAtTime(45, t);

        filter.type = 'lowpass';
        filter.frequency.setValueAtTime(90, t);

        gain.gain.setValueAtTime(0.0, t);
        gain.gain.linearRampToValueAtTime(0.2, t + 1.0);

        osc.connect(filter);
        filter.connect(gain);
        gain.connect(this.ctx.destination);
        osc.start(t);

        this.generatorNode = { osc, gain };
        }

        stopGeneratorRumble() {
        if (this.generatorNode) {
        const t = this.ctx.currentTime;
        this.generatorNode.gain.gain.linearRampToValueAtTime(0.0, t + 0.5);
        const localGenNode = this.generatorNode;
        setTimeout(() => {
        try {
        localGenNode.osc.stop();
        } catch(e){}
        }, 600);
        this.generatorNode = null;
        }
        }
        }

        const soundEngine = new HorrorSoundEngine();


        // --- PROCEDURAL DOKU OLUŞTURUCULARI (Düşük Boyut, Yüksek Detay, Tamamen Bedava) ---

        // 1. Kirli Hastane Duvarı (Altta Fayans, Üstte Kirli Alçı ve Yoğun Kan Lekeleri)
        function createWallTexture() {
        const canvas = document.createElement('canvas');
        canvas.width = 512;
        canvas.height = 512;
        const ctx = canvas.getContext('2d');

        // Baz Rengi (Kirli Krem/Sarı)
        ctx.fillStyle = '#cfc29d';
        ctx.fillRect(0, 0, 512, 512);

        // Gürültü ve Küf Efekti (Noise)
        for (let i = 0; i < 3000; i++) {
        const x = Math.random() * 512;
        const y = Math.random() * 512;
        const size = Math.random() * 2 + 1;
        ctx.fillStyle = Math.random() > 0.5 ? 'rgba(74, 69, 53, 0.15)' : 'rgba(38, 48, 30, 0.2)';
        ctx.fillRect(x, y, size, size);
        }

        // Alt fayans sınır çizgisi
        ctx.fillStyle = 'rgba(54, 48, 38, 0.4)';
        ctx.fillRect(0, 256, 512, 4);

        // Alt Kısma Fayans Izgarası Çizimi (Yatay ve dikey derzler)
        ctx.strokeStyle = 'rgba(54,48,38,0.25)';
        ctx.lineWidth = 1.5;
        const tileCols = 8;
        const tileRows = 4;
        const tileW = 512 / tileCols;
        const tileH = 256 / tileRows;

        // Alttaki fayansların rengini hafifçe yeşilimsi yapalım
        ctx.fillStyle = 'rgba(45, 65, 55, 0.12)';
        ctx.fillRect(0, 258, 512, 254);

        for (let r = 0; r < tileRows; r++) {
        const y = 256 + (r * tileH);
        ctx.beginPath();
        ctx.moveTo(0, y);
        ctx.lineTo(512, y);
        ctx.stroke();
        }
        for (let c = 0; c < tileCols; c++) {
        const x = c * tileW;
        ctx.beginPath();
        ctx.moveTo(x, 256);
        ctx.lineTo(x, 512);
        ctx.stroke();
        }

        // Büyük Duvar Lekeleri, Rutubet, Karartı
        for (let j = 0; j < 8; j++) {
        const grad = ctx.createRadialGradient(
        Math.random() * 512, Math.random() * 512, 10,
        Math.random() * 512, Math.random() * 512, Math.random() * 80 + 30
        );
        grad.addColorStop(0, 'rgba(40, 30, 10, 0.3)');
        grad.addColorStop(1, 'rgba(0,0,0,0)');
        ctx.fillStyle = grad;
        ctx.beginPath();
        ctx.arc(256, 256, 250, 0, Math.PI * 2);
        ctx.fill();
        }

        // DEHŞET VERİCİ KAN LEKELERİ (Kan Sıçramaları ve Akan Damlalar)
        ctx.fillStyle = 'rgba(110, 5, 5, 0.85)';
        for (let k = 0; k < 12; k++) {
        const bloodX = Math.random() * 512;
        const bloodY = Math.random() * 400 + 50;
        const radius = Math.random() * 8 + 3;

        // Ana sıçrama noktası
        ctx.beginPath();
        ctx.arc(bloodX, bloodY, radius, 0, Math.PI * 2);
        ctx.fill();

        // Aşağıya doğru akan kan çizgisi
        const dripLen = Math.random() * 70 + 20;
        ctx.strokeStyle = 'rgba(100, 3, 3, 0.8)';
        ctx.lineWidth = radius * 0.4;
        ctx.beginPath();
        ctx.moveTo(bloodX, bloodY);
        ctx.quadraticCurveTo(bloodX + (Math.random() * 6 - 3), bloodY + dripLen * 0.5, bloodX, bloodY + dripLen);
        ctx.stroke();

        // Küçük sıçrayan damlalar
        ctx.fillStyle = 'rgba(90, 0, 0, 0.9)';
        for (let d = 0; d < 5; d++) {
        ctx.beginPath();
        ctx.arc(bloodX + (Math.random() * 40 - 20), bloodY + (Math.random() * 40 - 20), Math.random() * 2 + 1, 0, Math.PI * 2);
        ctx.fill();
        }
        }

        const texture = new THREE.CanvasTexture(canvas);
        texture.wrapS = THREE.RepeatWrapping;
        texture.wrapT = THREE.RepeatWrapping;
        return texture;
        }

        // 2. Kirli Beton Yer Karoları ve Kan Göletleri
        function createFloorTexture() {
        const canvas = document.createElement('canvas');
        canvas.width = 512;
        canvas.height = 512;
        const ctx = canvas.getContext('2d');

        // Zemin Baz Rengi (Karanlık Beton Grisi)
        ctx.fillStyle = '#454545';
        ctx.fillRect(0, 0, 512, 512);

        // Eskitme ve Pürüzlülük (Noise)
        for (let i = 0; i < 4000; i++) {
        const x = Math.random() * 512;
        const y = Math.random() * 512;
        const size = Math.random() * 3 + 1;
        ctx.fillStyle = Math.random() > 0.5 ? 'rgba(20, 20, 20, 0.3)' : 'rgba(255, 255, 255, 0.05)';
        ctx.fillRect(x, y, size, size);
        }

        // Derz Çizgileri (Büyük Beton Bloklar)
        ctx.strokeStyle = '#1a1a1a';
        ctx.lineWidth = 3;
        ctx.strokeRect(0, 0, 512, 512);
        ctx.beginPath();
        ctx.moveTo(256, 0); ctx.lineTo(256, 512);
        ctx.moveTo(0, 256); ctx.lineTo(512, 256);
        ctx.stroke();

        // Rutubet, Karartı ve Pas Lekeleri
        for (let j = 0; j < 6; j++) {
        const x = Math.random() * 512;
        const y = Math.random() * 512;
        const r = Math.random() * 120 + 40;
        const grad = ctx.createRadialGradient(x, y, r * 0.1, x, y, r);
        grad.addColorStop(0, 'rgba(15, 12, 5, 0.6)');
        grad.addColorStop(1, 'rgba(0,0,0,0)');
        ctx.fillStyle = grad;
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.fill();
        }

        // ÇATLAKLAR (Zeminde beton kırıkları)
        ctx.strokeStyle = 'rgba(0, 0, 0, 0.8)';
        ctx.lineWidth = 1.5;
        for (let c = 0; c < 3; c++) {
        let startX = Math.random() * 512;
        let startY = Math.random() * 512;
        ctx.beginPath();
        ctx.moveTo(startX, startY);
        for (let step = 0; step < 5; step++) {
        startX += Math.random() * 40 - 20;
        startY += Math.random() * 40 - 20;
        ctx.lineTo(startX, startY);
        }
        ctx.stroke();
        }

        // YERDEKİ BÜYÜK KAN GÖLETLERİ (Blood Puddles)
        for (let b = 0; b < 4; b++) {
        const px = Math.random() * 400 + 50;
        const py = Math.random() * 400 + 50;
        const sizeX = Math.random() * 60 + 30;
        const sizeY = Math.random() * 30 + 15;
        const rotation = Math.random() * Math.PI;

        ctx.save();
        ctx.translate(px, py);
        ctx.rotate(rotation);

        // Dış gölge / yayılma halkası
        ctx.fillStyle = 'rgba(60, 0, 0, 0.4)';
        ctx.beginPath();
        ctx.ellipse(0, 0, sizeX * 1.1, sizeY * 1.1, 0, 0, Math.PI * 2);
        ctx.fill();

        // Parlak taze kan katmanı
        const grad = ctx.createRadialGradient(0, 0, 5, 0, 0, sizeX);
        grad.addColorStop(0, 'rgba(139, 0, 0, 0.9)');
        grad.addColorStop(0.8, 'rgba(80, 0, 0, 0.95)');
        grad.addColorStop(1, 'rgba(40, 0, 0, 1)');
        ctx.fillStyle = grad;

        ctx.beginPath();
        // Düzgün olmayan dalgalı bir gölet oluşturmak için oval çizimi bozuyoruz
        ctx.moveTo(sizeX, 0);
        for (let angle = 0; angle < Math.PI * 2; angle += 0.2) {
        const wave = 1 + Math.sin(angle * 5) * 0.12;
        const rx = sizeX * Math.cos(angle) * wave;
        const ry = sizeY * Math.sin(angle) * wave;
        ctx.lineTo(rx, ry);
        }
        ctx.closePath();
        ctx.fill();
        ctx.restore();
        }

        const texture = new THREE.CanvasTexture(canvas);
        texture.wrapS = THREE.RepeatWrapping;
        texture.wrapT = THREE.RepeatWrapping;
        return texture;
        }

        // 3. Tavan Plakaları Doku Oluşturucu
        function createCeilingTexture() {
        const canvas = document.createElement('canvas');
        canvas.width = 256;
        canvas.height = 256;
        const ctx = canvas.getContext('2d');

        ctx.fillStyle = '#656565';
        ctx.fillRect(0, 0, 256, 256);

        // Pürüzlülük
        for (let i = 0; i < 1500; i++) {
        ctx.fillStyle = 'rgba(0,0,0,0.15)';
        ctx.fillRect(Math.random()*256, Math.random()*256, 2, 2);
        }

        // Tavan Plaka Çerçevesi
        ctx.strokeStyle = '#2d2d2d';
        ctx.lineWidth = 4;
        ctx.strokeRect(0, 0, 256, 256);

        // Su sızıntısı ve rutubet sarılığı
        const grad = ctx.createRadialGradient(128, 128, 10, 128, 128, 100);
        grad.addColorStop(0, 'rgba(94, 80, 50, 0.35)');
        grad.addColorStop(1, 'rgba(0,0,0,0)');
        ctx.fillStyle = grad;
        ctx.beginPath(); ctx.arc(128, 128, 120, 0, Math.PI*2); ctx.fill();

        return new THREE.CanvasTexture(canvas);
        }

        // 4. Paslı Demir Hücre Kapısı Dokusu
        function createDoorTexture() {
        const canvas = document.createElement('canvas');
        canvas.width = 256;
        canvas.height = 512;
        const ctx = canvas.getContext('2d');

        // Baz Paslı Demir Rengi
        ctx.fillStyle = '#2c2520';
        ctx.fillRect(0, 0, 256, 512);

        // Metal Plaka Bölmeleri
        ctx.fillStyle = '#1e1a17';
        ctx.fillRect(15, 15, 226, 482);

        // Pas ve Kir Lekeleri
        for(let i=0; i<15; i++) {
        const rx = Math.random() * 256;
        const ry = Math.random() * 512;
        const rw = Math.random() * 60 + 10;
        const rh = Math.random() * 60 + 10;
        const grad = ctx.createRadialGradient(rx, ry, 2, rx, ry, Math.max(rw,rh));
        grad.addColorStop(0, 'rgba(139, 69, 19, 0.7)'); // Turuncu pas rengi
        grad.addColorStop(1, 'rgba(0,0,0,0)');
        ctx.fillStyle = grad;
        ctx.fillRect(rx-rw, ry-rh, rw*2, rh*2);
        }

        // Gözetleme penceresi mazgalı (Demir parmaklıklı pencere)
        ctx.fillStyle = '#000000';
        ctx.fillRect(68, 80, 120, 90);

        ctx.strokeStyle = '#4a4035';
        ctx.lineWidth = 6;
        ctx.strokeRect(68, 80, 120, 90);

        // Parmaklıklar
        ctx.strokeStyle = '#332b24';
        ctx.lineWidth = 4;
        for(let p = 90; p < 180; p += 25) {
        ctx.beginPath();
        ctx.moveTo(p, 80);
        ctx.lineTo(p, 170);
        ctx.stroke();
        }

        // Kan İzi (Gözetleme camından aşağı süzülen korkunç el izi)
        ctx.fillStyle = 'rgba(110, 0, 0, 0.75)';
        ctx.beginPath();
        ctx.arc(128, 175, 8, 0, Math.PI * 2);
        ctx.fill();
        ctx.fillRect(124, 175, 8, 40);

        return new THREE.CanvasTexture(canvas);
        }


